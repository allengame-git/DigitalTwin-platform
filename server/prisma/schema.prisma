generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// 專案
model Project {
  id            String             @id @default(uuid())
  name          String             @unique
  code          String             @unique
  description   String?
  originX       Float              @default(224000)
  originY       Float              @default(2429000)
  northAngle    Float              @default(0)
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  attitudes     Attitude[]
  boreholes     Borehole[]
  faultPlanes   FaultPlane[]
  geologyModels GeologyModel[]
  geophysics    Geophysics[]
  imagery       Imagery[]
  lithologies   ProjectLithology[]
  terrains      Terrain[]
  waterLevels    WaterLevel[]
  facilityScenes FacilityScene[]
  userProjects   UserProject[]
  modules        Module[]

  @@map("projects")
}

/// 模組實例（每個專案可有多個同類型模組）
model Module {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        String   // 'geology' | 'facility' | 'engineering' | 'simulation' | future types
  name        String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?

  // Data relations
  boreholes      Borehole[]
  geologyModels  GeologyModel[]
  faultPlanes    FaultPlane[]
  attitudes      Attitude[]
  terrains       Terrain[]
  waterLevels    WaterLevel[]
  imageries      Imagery[]
  geophysics     Geophysics[]
  lithologies    ProjectLithology[]
  facilityScenes FacilityScene[]

  // Viewer permissions
  userAccess UserProjectModule[]

  @@index([projectId])
  @@index([projectId, type])
  @@map("modules")
}

/// 專案岩性設定
model ProjectLithology {
  id        String   @id @default(uuid())
  projectId String
  lithId    Int
  code      String
  name      String
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId  String
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([projectId, code])
  @@unique([projectId, lithId])
  @@index([moduleId])
  @@map("project_lithologies")
}

/// 航照圖資料
model Imagery {
  id           String   @id @default(uuid())
  filename     String   @unique
  originalName String?
  year         Int
  name         String
  source       String?
  description  String?
  size         Int
  url          String
  thumbnailUrl String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  maxX         Float?
  maxY         Float?
  minX         Float?
  minY         Float?
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId     String
  module       Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@map("imagery")
}

/// 地球物理探查資料
model Geophysics {
  id           String   @id @default(uuid())
  filename     String   @unique
  originalName String?
  year         Int
  name         String
  lineId       String?
  method       String
  description  String?
  x1           Float
  y1           Float
  z1           Float
  x2           Float
  y2           Float
  z2           Float
  depthTop     Float?
  depthBottom  Float?
  size         Int
  url          String
  thumbnailUrl String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId     String
  module       Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@map("geophysics")
}

/// 3D 地質模型 (Voxel 資料)
model GeologyModel {
  id                 String   @id @default(uuid())
  filename           String   @unique
  originalName       String?
  version            String
  year               Int
  name               String
  description        String?
  sourceData         String?
  cellSizeX          Float?
  cellSizeY          Float?
  cellSizeZ          Float?
  minX               Float?
  maxX               Float?
  minY               Float?
  maxY               Float?
  minZ               Float?
  maxZ               Float?
  tilesetUrl         String?
  size               Int
  conversionStatus   String   @default("pending")
  conversionError    String?
  isActive           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  conversionProgress Int      @default(0)
  meshFormat         String?
  meshUrl            String?
  projectId          String?
  demFilePath        String?
  demOriginalName    String?
  project            Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId           String
  module             Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@map("geology_models")
}

/// 鑽孔資料
model Borehole {
  id          String             @id @default(uuid())
  boreholeNo  String
  name        String?
  x           Float
  y           Float
  elevation   Float
  totalDepth  Float
  drilledDate DateTime?
  contractor  String?
  area        String?
  description String?
  projectId   String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  layers      BoreholeLayer[]
  photos      BoreholePhoto[]
  properties  BoreholeProperty[]
  project     Project?           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId    String
  module      Module             @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([projectId, boreholeNo])
  @@index([moduleId])
  @@map("boreholes")
}

/// 鑽孔地層資料
model BoreholeLayer {
  id            String   @id @default(uuid())
  boreholeId    String
  topDepth      Float
  bottomDepth   Float
  lithologyCode String
  lithologyName String?
  description   String?
  createdAt     DateTime @default(now())
  borehole      Borehole @relation(fields: [boreholeId], references: [id], onDelete: Cascade)

  @@map("borehole_layers")
}

/// 鑽孔物性資料
model BoreholeProperty {
  id         String   @id @default(uuid())
  boreholeId String
  depth      Float
  nValue     Int?
  rqd        Float?
  createdAt  DateTime @default(now())
  borehole   Borehole @relation(fields: [boreholeId], references: [id], onDelete: Cascade)

  @@map("borehole_properties")
}

/// 鑽孔岩芯照片
model BoreholePhoto {
  id           String   @id @default(uuid())
  boreholeId   String
  depth        Float
  url          String
  thumbnailUrl String
  caption      String?
  createdAt    DateTime @default(now())
  borehole     Borehole @relation(fields: [boreholeId], references: [id], onDelete: Cascade)

  @@map("borehole_photos")
}

/// 斷層面資料
model FaultPlane {
  id           String            @id @default(uuid())
  name         String
  type         String
  dipAngle     Float
  dipDirection Float
  depth        Float
  color        String            @default("#ff4444")
  projectId    String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  coordinates  FaultCoordinate[]
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId     String
  module       Module            @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@map("fault_planes")
}

/// 斷層座標點
model FaultCoordinate {
  id           String     @id @default(uuid())
  faultPlaneId String
  x            Float
  y            Float
  z            Float
  sortOrder    Int
  faultPlane   FaultPlane @relation(fields: [faultPlaneId], references: [id], onDelete: Cascade)

  @@map("fault_coordinates")
}

/// 位態資料 (Strike/Dip)
model Attitude {
  id           String   @id @default(uuid())
  projectId    String
  x            Float
  y            Float
  z            Float
  strike       Float
  dip          Float
  dipDirection String?
  description  String?
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId     String
  module       Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@map("attitudes")
}

/// 地形資料 (DEM)
model Terrain {
  id           String   @id @default(uuid())
  projectId    String
  name         String
  filename     String   @unique
  originalName String?
  path         String
  heightmap    String
  texture      String?
  satelliteTexture String?
  minX         Float
  maxX         Float
  minY         Float
  maxY         Float
  minZ         Float
  maxZ         Float
  width        Int
  height       Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId     String
  module       Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@map("terrains")
}

/// 地下水位面
model WaterLevel {
  id           String   @id @default(uuid())
  projectId    String
  name         String
  sourceType   String   // 'well' | 'simulation'
  filename     String   @unique
  originalName String?
  path         String
  heightmap    String
  minX         Float
  maxX         Float
  minY         Float
  maxY         Float
  minZ         Float
  maxZ         Float
  width        Int
  height       Int
  pointCount   Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId     String
  module       Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@map("water_levels")
}

/// 設施場景資訊類型
enum FacilityInfoType {
  TEXT
  IMAGE
  DOCUMENT
  LINK
}

/// 設施導覽場景 (可巢狀)
model FacilityScene {
  id                  String          @id @default(uuid())
  projectId           String
  parentSceneId       String?
  parentModelId       String?         // 此場景隸屬於哪個模型（子場景時使用）
  name                String
  description         String?
  planImageUrl        String?
  autoPlanImageUrl    String?
  cameraPosition      Json?
  cameraTarget        Json?
  terrainCsvUrl       String?
  terrainHeightmapUrl String?
  terrainTextureUrl   String?
  terrainTextureMode  String?
  terrainBounds       Json?
  coordShiftX         Float           @default(0)
  coordShiftY         Float           @default(0)
  coordShiftZ         Float           @default(0)
  coordRotation       Float           @default(0)
  sortOrder           Int             @default(0)
  sceneBounds         Json?           // { width, depth, height } 米; null=自動計算
  sceneType           String          @default("normal")   // "lobby" | "normal"
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  project             Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId            String
  module              Module          @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  parentScene         FacilityScene?  @relation("SceneHierarchy", fields: [parentSceneId], references: [id], onDelete: Cascade)
  childScenes         FacilityScene[] @relation("SceneHierarchy")
  parentModel         FacilityModel?  @relation("ModelChildScenes", fields: [parentModelId], references: [id], onDelete: SetNull)
  models              FacilityModel[] @relation("SceneModels")

  @@index([projectId])
  @@index([moduleId])
  @@index([parentSceneId])
  @@index([parentModelId])
  @@map("facility_scenes")
}

/// 設施 3D 模型
model FacilityModel {
  id          String              @id @default(uuid())
  sceneId     String
  name        String
  modelUrl    String
  fileSize    Int
  introduction String?
  position    Json                @default("{\"x\":0,\"y\":0,\"z\":0}")
  rotation    Json                @default("{\"x\":0,\"y\":0,\"z\":0}")
  scale       Json                @default("{\"x\":1,\"y\":1,\"z\":1}")
  sortOrder   Int                 @default(0)
  modelType   String              @default("primary")  // "primary" | "decorative"
  planX       Float?              // 平面圖 X 百分比 (0~100)，null = 用 3D position 自動映射
  planY       Float?              // 平面圖 Y 百分比 (0~100)
  planVisible Boolean             @default(true) // false = 在平面圖隱藏
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  scene       FacilityScene       @relation("SceneModels", fields: [sceneId], references: [id], onDelete: Cascade)
  childScenes FacilityScene[]     @relation("ModelChildScenes")
  infos       FacilityModelInfo[]
  animations  FacilityAnimation[]

  @@index([sceneId])
  @@map("facility_models")
}

/// 設施模型動畫
model FacilityAnimation {
  id            String        @id @default(uuid())
  modelId       String
  name          String
  type          String        @default("keyframe")   // "keyframe" | "gltf"
  trigger       String        @default("auto")       // "auto" | "manual"
  loop          Boolean       @default(true)
  duration      Float         @default(5)            // seconds
  easing        String        @default("linear")     // "linear" | "easeIn" | "easeOut" | "easeInOut"
  gltfClipName  String?                              // GLB 內嵌動畫名稱
  pathMode      String        @default("linear")     // "linear" | "catmullrom"
  autoOrient    Boolean       @default(false)        // 自動沿路徑切線方向旋轉
  keyframes     Json          @default("[]")         // [{ time, position, rotation, scale }]
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  model         FacilityModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("facility_animations")
}

/// 設施模型資訊 (Rich Content)
model FacilityModelInfo {
  id        String           @id @default(uuid())
  modelId   String
  type      FacilityInfoType
  label     String
  content   String
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  model     FacilityModel    @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("facility_model_infos")
}

// ── 帳號管理 ──────────────────────────────────────────

enum UserRole {
  engineer
  viewer
  public
  admin
}

enum AccountStatus {
  active
  locked
  disabled
  pending_reset
}

model User {
  id                 String        @id @default(uuid())
  email              String        @unique
  passwordHash       String
  name               String
  role               UserRole      @default(engineer)
  status             AccountStatus @default(active)
  mustChangePassword Boolean       @default(false)
  passwordChangedAt  DateTime?
  failedLoginCount   Int           @default(0)
  lockedUntil        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  lastLoginAt        DateTime?
  sessions           Session[]
  auditLogs          AuditLog[]
  userProjects       UserProject[]

  @@map("users")
}

model Session {
  id             String   @id @default(uuid())
  userId         String
  refreshToken   String   @unique
  userAgent      String?
  ipAddress      String?
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  lastActivityAt DateTime @default(now())
  isRevoked      Boolean  @default(false)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  TOKEN_REFRESH
  PASSWORD_CHANGE
  PASSWORD_RESET
  ACCOUNT_CREATE
  ACCOUNT_UPDATE
  ACCOUNT_DISABLE
  ACCOUNT_UNLOCK
  SESSION_REVOKED
}

model AuditLog {
  id        String      @id @default(uuid())
  userId    String?
  action    AuditAction
  ipAddress String?
  userAgent String?
  details   Json?
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model UserProject {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  createdBy String?

  modules   UserProjectModule[]

  @@unique([userId, projectId])
  @@map("user_projects")
}

model UserProjectModule {
  id            String      @id @default(uuid())
  userProjectId String
  moduleId      String
  userProject   UserProject @relation(fields: [userProjectId], references: [id], onDelete: Cascade)
  module        Module      @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userProjectId, moduleId])
  @@index([moduleId])
  @@map("user_project_modules")
}
