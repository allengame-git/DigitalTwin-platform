generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// 專案
model Project {
  id            String             @id @default(uuid())
  name          String             @unique
  code          String             @unique
  description   String?
  originX       Float              @default(224000)
  originY       Float              @default(2429000)
  northAngle    Float              @default(0)
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  attitudes     Attitude[]
  boreholes     Borehole[]
  faultPlanes   FaultPlane[]
  geologyModels GeologyModel[]
  geophysics    Geophysics[]
  imagery       Imagery[]
  lithologies   ProjectLithology[]
  terrains      Terrain[]

  @@map("projects")
}

/// 專案岩性設定
model ProjectLithology {
  id        String   @id @default(uuid())
  projectId String
  lithId    Int
  code      String
  name      String
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, code])
  @@unique([projectId, lithId])
  @@map("project_lithologies")
}

/// 航照圖資料
model Imagery {
  id           String   @id @default(uuid())
  filename     String   @unique
  originalName String?
  year         Int
  name         String
  source       String?
  description  String?
  size         Int
  url          String
  thumbnailUrl String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  maxX         Float?
  maxY         Float?
  minX         Float?
  minY         Float?
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("imagery")
}

/// 地球物理探查資料
model Geophysics {
  id           String   @id @default(uuid())
  filename     String   @unique
  originalName String?
  year         Int
  name         String
  lineId       String?
  method       String
  description  String?
  x1           Float
  y1           Float
  z1           Float
  x2           Float
  y2           Float
  z2           Float
  depthTop     Float?
  depthBottom  Float?
  size         Int
  url          String
  thumbnailUrl String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("geophysics")
}

/// 3D 地質模型 (Voxel 資料)
model GeologyModel {
  id                 String   @id @default(uuid())
  filename           String   @unique
  originalName       String?
  version            String
  year               Int
  name               String
  description        String?
  sourceData         String?
  cellSizeX          Float?
  cellSizeY          Float?
  cellSizeZ          Float?
  minX               Float?
  maxX               Float?
  minY               Float?
  maxY               Float?
  minZ               Float?
  maxZ               Float?
  tilesetUrl         String?
  size               Int
  conversionStatus   String   @default("pending")
  conversionError    String?
  isActive           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  conversionProgress Int      @default(0)
  meshFormat         String?
  meshUrl            String?
  projectId          String?
  demFilePath        String?
  demOriginalName    String?
  project            Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("geology_models")
}

/// 鑽孔資料
model Borehole {
  id          String             @id @default(uuid())
  boreholeNo  String
  name        String?
  x           Float
  y           Float
  elevation   Float
  totalDepth  Float
  drilledDate DateTime?
  contractor  String?
  area        String?
  description String?
  projectId   String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  layers      BoreholeLayer[]
  photos      BoreholePhoto[]
  properties  BoreholeProperty[]
  project     Project?           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, boreholeNo])
  @@map("boreholes")
}

/// 鑽孔地層資料
model BoreholeLayer {
  id            String   @id @default(uuid())
  boreholeId    String
  topDepth      Float
  bottomDepth   Float
  lithologyCode String
  lithologyName String?
  description   String?
  createdAt     DateTime @default(now())
  borehole      Borehole @relation(fields: [boreholeId], references: [id], onDelete: Cascade)

  @@map("borehole_layers")
}

/// 鑽孔物性資料
model BoreholeProperty {
  id         String   @id @default(uuid())
  boreholeId String
  depth      Float
  nValue     Int?
  rqd        Float?
  createdAt  DateTime @default(now())
  borehole   Borehole @relation(fields: [boreholeId], references: [id], onDelete: Cascade)

  @@map("borehole_properties")
}

/// 鑽孔岩芯照片
model BoreholePhoto {
  id           String   @id @default(uuid())
  boreholeId   String
  depth        Float
  url          String
  thumbnailUrl String
  caption      String?
  createdAt    DateTime @default(now())
  borehole     Borehole @relation(fields: [boreholeId], references: [id], onDelete: Cascade)

  @@map("borehole_photos")
}

/// 斷層面資料
model FaultPlane {
  id           String            @id @default(uuid())
  name         String
  type         String
  dipAngle     Float
  dipDirection Float
  depth        Float
  color        String            @default("#ff4444")
  projectId    String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  coordinates  FaultCoordinate[]
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("fault_planes")
}

/// 斷層座標點
model FaultCoordinate {
  id           String     @id @default(uuid())
  faultPlaneId String
  x            Float
  y            Float
  z            Float
  sortOrder    Int
  faultPlane   FaultPlane @relation(fields: [faultPlaneId], references: [id], onDelete: Cascade)

  @@map("fault_coordinates")
}

/// 位態資料 (Strike/Dip)
model Attitude {
  id           String   @id @default(uuid())
  projectId    String
  x            Float
  y            Float
  z            Float
  strike       Float
  dip          Float
  dipDirection String?
  description  String?
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("attitudes")
}

/// 地形資料 (DEM)
model Terrain {
  id           String   @id @default(uuid())
  projectId    String
  name         String
  filename     String   @unique
  originalName String?
  path         String
  heightmap    String
  texture      String?
  minX         Float
  maxX         Float
  minY         Float
  maxY         Float
  minZ         Float
  maxZ         Float
  width        Int
  height       Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("terrains")
}
